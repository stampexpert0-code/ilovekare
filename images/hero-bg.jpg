}
  &.with-nav {
  & .nav-heading-left { margin-block-end: 0.5rem; }
}
  &.with-heading-right {
  & .nav-heading-left { margin-inline-end: 1rem; }
}
  &.with-before-nav-heading {
  & .nav-heading-left {
  & .nav-heading-subheading-lockup { margin-inline-start: 1rem; }
