.editable-element { cursor: pointer; position: relative; }

.editable-element::after { border: 4px solid rgba(0, 0, 0, 0); border-radiu=
s: 4px; inset: -3px; content: ""; opacity: 0; position: absolute; transitio=
n: 0.3s; z-index: -1; }

.editable-element.ux-editor-field-highlight::after, .editable-element:hover=
::after { background-color: rgba(65, 160, 255, 0.3); opacity: 1; z-index: 1=
; }

.editable-element.ux-editor-field-highlight[data-ux*=3D"Background"]::after=
, .editable-element:hover[data-ux*=3D"Background"]::after { background-colo=
r: rgba(0, 0, 0, 0); border: 4px solid rgb(65, 160, 255); }

.editable-element .editable-element:hover::after { background-color: rgba(0=
, 0, 0, 0); border-width: medium; border-style: none; border-color: current=
color; border-image: initial; }

.editable-element [data-page], .editable-element [data-section-jump] { poin=
ter-events: none; }

.editable-element .inline-editable-element { cursor: text; }

[data-ux*=3D"Header"] [data-ux*=3D"Background"], [data-ux*=3D"Header"] [dat=
a-ux*=3D"WrapperImage"] { z-index: auto; }

[data-ux*=3D"Header"] [data-ux*=3D"Background"]::after, [data-ux*=3D"Header=
"] [data-ux*=3D"WrapperImage"]::after { display: none; }

.inline-editable-element { cursor: text; position: relative; z-index: 2; }

.inline-editable-element .inline-highlight { border-radius: 2px; inset: 0px=
; margin: -4px -8px; opacity: 0; position: absolute; visibility: hidden; z-=
index: -1; }

.inline-editable-element[data-ux*=3D"SectionHeading"] { padding-left: 10px;=
 padding-right: 10px; margin-left: -10px !important; margin-right: -10px !i=
mportant; }

.inline-editable-element[data-ux*=3D"SectionHeading"] .inline-highlight { i=
nset: 0px; margin: 0px; opacity: 0; z-index: -1; }

.inline-editable-element .ux-editor-field-highlight + .inline-highlight, .i=
nline-editable-element.selected .inline-highlight, .inline-editable-element=
:hover .inline-highlight { opacity: 1; visibility: visible; }

.inline-editable-element .ux-editor-field-highlight + .inline-highlight, .i=
nline-editable-element .ux-editor-field-highlight[data-ux*=3D"Background"]:=
:after, .inline-editable-element.selected .inline-highlight, .inline-editab=
le-element:hover .inline-highlight, .inline-editable-element:hover[data-ux*=
=3D"Background"]::after { border: 2px solid rgb(65, 160, 255); }

.inline-editable-element.selected .public-DraftEditor-content { cursor: tex=
t; }

.inline-editable-element [data-page], .inline-editable-element [data-sectio=
n-jump] { pointer-events: none; }

[data-ux=3D"ContentCards"] .inline-editable-element { width: inherit; }

[data-ux=3D"SectionSplitHeading"] .inline-highlight { inset: 0px; margin: 0=
px; }

@media (-ms-high-contrast:none), screen and (-ms-high-contrast:active) {
  .theme-preview-grid { display: flex !important; flex-wrap: wrap; }
  .theme-preview-grid .theme-preview-item { flex-basis: 48%; margin: 1%; }
}

.overlay-spinner-background { background-color: rgba(0, 0, 0, 0.4); }

.overlay-spinner-label-container { border-radius: 4px; padding: 4px 8px; }

.overlay-spinner-fit-container { inset: 0px; position: absolute; }

body, html { height: 100vh; }

body { line-height: 1.5rem; overflow: hidden; margin-inline: 0px !important=
; }

body.uxp-delegation { overflow-y: auto; }

body.sidebar-locked { margin-inline: 0px !important; }

body.sidebar-locked .ux-flyout.context-switcher-list { z-index: 1004; }

#app-header .global-utility-nav, #app-header .horizontal-navigation { displ=
ay: none; }

#app-header #hcs-header-container { margin-block-end: 0px; padding: 0px; }

#app-header .nav-wrapper { display: none; }

#app-header .nav-wrapper::before { background-color: rgba(0, 0, 0, 0.4); co=
ntent: ""; height: 100vh; left: 0px; position: absolute; top: 0px; width: 1=
00vw; z-index: 1002; }

#app-header .nav-wrapper .nav-toggle { opacity: 0; pointer-events: none; vi=
sibility: hidden; }

#app-header .nav-wrapper .sidebar-wrapper { z-index: 1003; }

#app-header .nav-wrapper .sidebar-wrapper .ApplicationSidebar_VentureName {=
 line-height: normal; }

#app-header .nav-wrapper .sidebar-wrapper .ApplicationSidebar_VentureName s=
vg { height: 24px; width: 24px; }

#app-header .nav-wrapper .sidebar-nav-link.open, #app-header .nav-wrapper .=
sidebar-nav-link:focus, #app-header .nav-wrapper .sidebar-nav-link:hover { =
color: var(--ux-1leynsm) !important; }

#app-header .nav-wrapper .sidebar-nav-link:hover .nav-link-subnav-toggle { =
background-color: rgba(17, 17, 17, 0.1); }

#app-header .nav-wrapper .sidebar-nav-close-desktop { color: inherit; curso=
r: pointer; font-size: 20px; inset-block-start: 46px; inset-inline-end: 14p=
x; position: absolute; }

#app-header .nav-wrapper .sidebar-component-mobile { transform: translateX(=
0px) !important; z-index: 1003; }

