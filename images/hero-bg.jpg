.uxicon-plus::before { content: var(--uxp-icon-plus); }

.section-actions-container { position: relative; z-index: 1002; }

.section-actions-pill-wrapper { align-items: center; display: flex; left: 5=
0%; opacity: 1; position: absolute; top: -26px; transition: opacity 0.5s ea=
se-in-out; }

.section-actions-pill-wrapper.hide { opacity: 0; }

.section-actions-pill { align-items: center; background: rgb(0, 164, 166); =
border-radius: 24px; display: flex; gap: 0px; padding: 4px; }

.pill-button { align-items: center; background: rgba(0, 0, 0, 0); border-wi=
dth: medium; border-style: none; border-color: currentcolor; border-image: =
initial; border-radius: 50%; color: rgb(255, 255, 255); cursor: pointer; di=
splay: flex; height: 44px; justify-content: center; transition: 0.15s; widt=
h: 44px; }

.pill-button:hover { background: rgba(0, 0, 0, 0.15); color: rgb(255, 255, =
255); }

.pill-button.disabled { cursor: not-allowed; opacity: 0.4; }

.pill-button.disabled:hover { background: rgba(0, 0, 0, 0); color: rgb(255,=
 255, 255); }

.pill-button .uxicon { margin: 0px; }

.pill-button--add.pulse-btn { animation: 1.75s ease 0s infinite normal none=
 running addSectionButtonPulse; }

.pill-button--add:hover.pulse-btn { animation: auto ease 0s 1 normal none r=
unning none; }

.pill-button--divider.pill-button--divider-active { background: rgba(0, 0, =
0, 0.15); color: rgb(255, 255, 255); }

.divider-picker-trigger { align-items: center; background: rgba(0, 0, 0, 0)=
; border-width: medium; border-style: none; border-color: currentcolor; bor=
der-image: initial; border-radius: 50%; color: rgb(255, 255, 255); cursor: =
pointer; display: flex; height: 44px; justify-content: center; transition: =
0.15s; width: 44px; }

.divider-picker-trigger--active, .divider-picker-trigger--open, .divider-pi=
cker-trigger:hover { background: rgba(0, 0, 0, 0.15); color: rgb(255, 255, =
255); }

.section-actions-pill-limit { left: 50%; position: absolute; top: 50px; tra=
nsform: translateX(-50%); }

@media (min-width: 992px) {
  .show-hover-preview.section-actions-pill-wrapper { opacity: 0; }
  .show-inline-controls:hover .show-hover-preview.section-actions-pill-wrap=
per:not(.hide) { opacity: 1; }
}

@keyframes addSectionButtonPulse {=20
  0% { box-shadow: rgba(0, 164, 166, 0.4) 0px 0px 0px 0px; }
  70% { box-shadow: rgba(0, 164, 166, 0) 0px 0px 0px 10px; }
  100% { box-shadow: rgba(0, 164, 166, 0) 0px 0px 0px 0px; }
}

.pill-button-wrapper { align-items: center; display: flex; justify-content:=
 center; position: relative; }

.pill-tooltip { background: rgb(255, 255, 255); border-radius: 4px; box-sha=
dow: rgba(0, 0, 0, 0.15) 0px 2px 8px; color: rgb(17, 17, 17); display: none=
; font-size: 13px; left: 50%; margin-top: 8px; opacity: 0; padding: 6px 10p=
x; pointer-events: none; position: absolute; top: 100%; transform: translat=
eX(-50%); white-space: nowrap; z-index: 1000; }

.pill-button-wrapper:hover .pill-tooltip { animation: 2s ease 0s 1 normal n=
one running pillTooltipShow; display: block; }

@keyframes pillTooltipShow {=20
  0% { opacity: 0; }
  5% { opacity: 1; }
  80% { opacity: 1; }
  100% { opacity: 0; }
}

@keyframes showAndHide {=20
  0% { opacity: 0; }
  2% { opacity: 0; }
  3% { opacity: 1; }
  80% { opacity: 1; }
  100% { opacity: 0; }
}

.text-tooltip { background: rgb(255, 255, 238); border: 1px solid rgb(238, =
238, 221); border-radius: 4px; color: rgb(0, 0, 0); display: none; font-fam=
ily: Arial, sans_serif; font-size: 11pt; opacity: 0; padding: 4px 8px; posi=
tion: absolute; z-index: 1000; text-transform: none !important; }

.text-tooltip.add-section { right: 0px; top: 65px; white-space: nowrap; }

@media (max-width: 500px) {
  .text-tooltip.add-section { white-space: normal; width: calc(-35px + 100v=
w); }
}

.text-tooltip.add-section-btn-limit { left: 20px; top: 55px; }

.text-tooltip.add-section-btn-limit.tooltip-right { left: auto; right: 20px=
; }

.text-tooltip.add-section-plus-limit { left: calc(50% + 30px); min-width: 2=
50px; top: 50px; }

@media (max-width: 500px) {
  .text-tooltip.add-section-plus-limit { left: calc(35px - 50vw); margin: 0=
px 10px; min-width: auto; text-align: center; top: 65px; width: calc(-35px =
+ 100vw); }
}

.text-tooltip.add-section-this-page-limit { left: 20px; margin-top: 5px; }

.text-tooltip.members-only { right: 52px; top: 45px; white-space: nowrap; }

:hover + .text-tooltip { animation: 2s ease 0.05s 1 normal none running sho=
wAndHide; display: block; }

.divider-picker-container { background-color: rgb(255, 255, 255); border-ra=
dius: 8px; box-shadow: rgba(0, 0, 0, 0.2) 0px 8px 24px; max-height: 500px; =
overflow-y: auto; width: 320px; }

.divider-picker-header { align-items: center; border-bottom: 1px solid rgb(=
238, 238, 238); display: flex; justify-content: space-between; padding: 12p=
x 16px; }

.divider-picker-title { color: rgb(17, 17, 17); font-size: 14px; font-weigh=
t: 600; }

.divider-picker-remove { background: none; border-width: medium; border-sty=
le: none; border-color: currentcolor; border-image: initial; border-radius:=
 4px; color: rgb(102, 102, 102); cursor: pointer; font-size: 12px; padding:=
 4px 8px; }

.divider-picker-remove:hover { background: rgb(245, 245, 245); color: rgb(5=
1, 51, 51); }

.divider-picker-grid { display: grid; gap: 8px; grid-template-columns: repe=
at(4, 1fr); max-height: 200px; overflow-y: auto; padding: 12px; }

.divider-preset-btn { align-items: flex-end; background: rgb(245, 245, 245)=
; border: 2px solid rgba(0, 0, 0, 0); border-radius: 6px; cursor: pointer; =
display: flex; height: 40px; overflow: hidden; padding: 4px; transition: 0.=
15s; }

.divider-preset-btn:hover { background: rgb(238, 238, 238); border-color: r=
gb(221, 221, 221); }

.divider-preset-btn[data-selected=3D"true"] { background: rgba(2, 197, 76, =
0.1); border-color: rgb(2, 197, 76); }

.divider-preset-btn svg { height: 100%; width: 100%; }

.divider-picker-sliders { border-top: 1px solid rgb(238, 238, 238); padding=
: 12px 16px; }

.divider-slider-section { margin-bottom: 16px; padding: 4px 0px; }

.divider-slider-section:last-child { margin-bottom: 0px; }

.divider-slider-label { color: rgb(102, 102, 102); font-size: 12px; padding=
-right: 12px; white-space: nowrap; }

.divider-slider-section .ux-slider { align-items: center; display: flex; }

.divider-slider-section .ux-slider-main { flex: 1 1 0%; }

.divider-slider-section .ux-slider-value-labels { display: none; }

.divider-slider-section .ux-slider-bar { height: 20px; position: relative; =
width: 100%; }

.divider-slider-section .ux-slider-bar .ux-slider-area { align-items: cente=
r; border-radius: 2px; display: flex; height: 2px; position: absolute; top:=
 9px; width: 100%; background-color: rgb(97, 103, 121) !important; }

.divider-slider-section .ux-slider-bar .ux-slider-fill { border-radius: 2px=
; display: block; height: 2px; overflow: hidden; position: absolute; backgr=
ound-color: rgb(0, 164, 166) !important; }

.divider-slider-section .ux-slider-bar .ux-slider-thumb { border-radius: 50=
%; cursor: pointer; display: block; height: 16px; overflow: hidden; positio=
n: absolute; top: 2px; transform: translate(-50%); width: 16px; background-=
color: rgb(0, 164, 166) !important; border-width: medium !important; border=
-style: none !important; border-color: currentcolor !important; border-imag=
e: initial !important; }
