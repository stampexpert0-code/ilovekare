  & .in-page-nav-headline {
  align-items: flex-start; display: flex; justify-content: space-between;
  & .nav-heading-left {
  align-items: center; display: flex; justify-content: flex-start;
  & .nav-heading-subheading-lockup {
  & .headline-wrapper {
  align-items: center; display: flex; justify-content: flex-start;
