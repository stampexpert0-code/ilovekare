.mx-inline-el-scaler .ux-slider-main { align-items: center; display: flex; =
}

.mx-inline-el-scaler .ux-slider-thumb { background-color: rgb(255, 255, 255=
) !important; }

.mx-inline-el-scaler .ux-slider-range-indicator.left svg, .mx-inline-el-sca=
ler .ux-slider-range-indicator.right svg { width: unset; }

.mx-inline-el-scaler.mx-inline-image-scaler { max-width: 500px; min-width: =
180px; }

.mx-no-drag { -webkit-user-drag: none; user-select: none; }

@media only screen and (min-device-width: 1025px) {
}

@media (min-width: 767px) {
  .mx-el-datepicker .ux-calendar { padding: 2px; }
}

@media (max-width: 768px) {
  .mx-image .mx-image-overlay-opacity { margin-top: 0px; }
}

